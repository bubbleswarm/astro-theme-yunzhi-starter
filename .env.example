# ============================================================
# 第三方集成配置（全部可选，不配置则对应功能不启用）
# ============================================================

# --- Umami 网站统计（可选）---
# 在 https://umami.is 注册并创建站点后获取
UMAMI_WEBSITE_ID=
UMAMI_HOST=

# --- Giscus 评论系统（可选）---
# 在 https://giscus.app 配置后获取
# 也可以在 src/config.ts 中直接填写 integrations.giscus
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=
