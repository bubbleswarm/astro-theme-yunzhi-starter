{
  "name": "astro-theme-yunzhi-starter",
  "version": "1.0.0",
  "description": "A beautiful Astro blog theme starter with DaisyUI, dual themes, and full-featured blog support.",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 8080",
    "start": "astro dev",
    "build": "astro build",
    "build:search": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "clean": "rimraf dist .astro node_modules/.vite coverage .cache pagefind",
    "lint": "cross-env BIOME_CONFIG_PATH=./biome.json biome check .",
    "lint:fix": "cross-env BIOME_CONFIG_PATH=./biome.json biome check --write .",
    "format": "cross-env BIOME_CONFIG_PATH=./biome.json biome format --write .",
    "format:check": "cross-env BIOME_CONFIG_PATH=./biome.json biome format .",
    "prepare": "lefthook install",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "check": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@nanostores/react": "^1.1.0",
    "@yeskunall/astro-umami": "^0.0.8",
    "astro": "^6.1.8",
    "astro-seo": "^1.1.0",
    "daisyui": "^5.5.19",
    "dayjs": "^1.11.20",
    "harmonyos-sans-sc-webfont-splitted": "^1.1.0",
    "lucide-react": "^1.8.0",
    "nanostores": "^1.3.0",
    "pagefind": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "overrides": {
    "vite": "^7.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "lefthook": "^2.1.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
