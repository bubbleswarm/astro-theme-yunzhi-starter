---
import { formatDateTimeSeconds } from '@/utils/formatDate';

interface Props {
  title: string;
  pubDate: number;
  readingTime: number;
  wordCount: number;
  category?: string;
  tags: string[];
}

const { title, pubDate, readingTime, wordCount, category, tags } = Astro.props;
---

<div class="article-title-card glass-card">
  <h1 class="article-title">{title}</h1>

  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-base-content/60 mb-4">
    <span class="inline-flex items-center gap-1.5" data-local-time={pubDate}>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="发布日期">
        <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
        <line x1="16" x2="16" y1="2" y2="6" />
        <line x1="8" x2="8" y1="2" y2="6" />
        <line x1="3" x2="21" y1="10" y2="10" />
      </svg>
      {formatDateTimeSeconds(pubDate)}
    </span>
    <span class="inline-flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="阅读时间">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      {readingTime} 分钟阅读
    </span>
    <span class="inline-flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="字数">
        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
        <polyline points="14 2 14 8 20 8" />
      </svg>
      {wordCount.toLocaleString()} 字
    </span>
    {
      category && (
        <span class="inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="分类">
            <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
          </svg>
          <span class="badge badge-primary badge-soft badge-sm">{category}</span>
        </span>
      )
    }
  </div>

  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-badge">
            {tag}
          </a>
        ))}
      </div>
    )
  }
</div>

<style>
  .article-title-card {
    padding: 32px;
    margin-bottom: 24px;
    border-radius: var(--border-radius-lg, 16px);
  }

  .article-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 20px;
    color: var(--text-primary, rgba(0, 0, 0, 0.88));
  }

  @media (min-width: 768px) {
    .article-title {
      font-size: 2.5rem;
    }
  }
</style>
