---
import type { BlogPost } from '../../types/blog';
import PostCard from './PostCard.astro';
import PostPagination from './PostPagination.astro';

interface Props {
  posts: BlogPost[];
  pageSize?: number;
}

const { posts, pageSize = 10 } = Astro.props;
const showPagination = posts.length > pageSize;
const featuredMode = posts.length <= 3;
---

<div class="post-list-wrapper" data-total={posts.length} data-page-size={pageSize}>
  <div class="flex flex-col gap-5" id="post-list-cards">
    {posts.map((post, index) => (
      <div class="post-card-wrapper" data-index={index} style={index >= pageSize ? 'display: none;' : undefined}>
        <PostCard post={post} index={index} size={featuredMode ? 'large' : 'default'} />
      </div>
    ))}
  </div>

  {showPagination && <PostPagination total={posts.length} pageSize={pageSize} />}
</div>

<script>
  import './postListPagination.ts';
</script>

<style>
  @media (max-width: 480px) {
    #post-list-page-size {
      display: none;
    }
    .pagination-wrapper {
      justify-content: center;
      padding: 12px;
    }
  }
</style>
