---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="responsive-sidebar-section">
  <div class="responsive-sidebar-title">
    <span>{title}</span>
  </div>
  <div class="responsive-sidebar-content">
    <slot />
  </div>
</div>

<style>
  .responsive-sidebar-section {
    border: none;
    background: none;
    margin-bottom: 0;
  }
  .responsive-sidebar-title {
    display: none;
  }
  .responsive-sidebar-content {
    display: block;
  }

  @media (max-width: 1024px) {
    .responsive-sidebar-section {
      border: 1px solid var(--color-base-300);
      border-radius: 12px;
      background: var(--color-base-200);
      margin-bottom: 16px;
      overflow: hidden;
    }
    .responsive-sidebar-title {
      display: block;
      padding: 12px 16px;
      font-weight: 600;
      font-size: 0.9375rem;
      color: var(--color-base-content);
      user-select: none;
    }
    .responsive-sidebar-content {
      padding: 0 16px 16px;
    }
    .responsive-sidebar-content :global(.sidebar-section-title) {
      display: none;
    }
  }
</style>
