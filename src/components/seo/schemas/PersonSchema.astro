---
interface Props {
  name: string;
  url?: string;
  email?: string;
  image?: string;
  sameAs?: string[];
}

const { name, url, email, image, sameAs } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  ...(url ? { url } : {}),
  ...(email ? { email } : {}),
  ...(image ? { image } : {}),
  ...(sameAs && sameAs.length > 0 ? { sameAs } : {}),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
