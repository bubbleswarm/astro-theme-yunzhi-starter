---
import type { SidebarData } from '../../utils/sidebar';
import TagCloud from '../blog/TagCloud.astro';
import ResponsiveSidebarSection from '../layout/ResponsiveSidebarSection.astro';
import { AboutWidget } from './AboutWidget';
import { LatestMoments } from './LatestMoments';

interface Props {
  data: SidebarData;
}

const { data } = Astro.props;
const { tags, site, moments } = data;
---

<aside>
	<ResponsiveSidebarSection title="关于博主">
		<AboutWidget site={site} client:visible />
	</ResponsiveSidebarSection>
	<ResponsiveSidebarSection title="最新说说">
		<LatestMoments moments={moments} client:visible />
	</ResponsiveSidebarSection>
	<ResponsiveSidebarSection title="热门标签">
		<div class="rounded-2xl border border-base-300 bg-base-200/90 backdrop-blur-xl p-5 shadow-md mb-6">
			<h3 class="sidebar-section-title text-base font-semibold mb-4 text-base-content">
				热门标签
			</h3>
			<TagCloud tags={tags} />
		</div>
	</ResponsiveSidebarSection>
</aside>
