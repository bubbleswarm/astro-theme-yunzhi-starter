---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面不存在" noindex={true}>
  <div class="py-16 text-center">
    <div class="mb-6">
      <div class="text-[120px] text-primary font-bold">404</div>
      <h2 class="text-base-content/70 mb-6">抱歉，您访问的页面不存在</h2>
      <a href="/" class="inline-block px-4 py-2 bg-primary text-primary-content rounded no-underline hover:no-underline">
        返回首页
      </a>
    </div>
  </div>
</BaseLayout>
