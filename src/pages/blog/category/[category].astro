---
export const prerender = true;

import PostList from '../../../components/blog/PostList.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';
import { CategoryList } from '../../../components/sidebar/CategoryList';
import Sidebar from '../../../components/sidebar/Sidebar.astro';
import { SITE_URL } from '../../../consts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageLayout from '../../../layouts/PageLayout.astro';
import { getAllCategories, getPostsByCategory } from '../../../utils/posts';
import { getSidebarData } from '../../../utils/sidebar';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((cat) => ({
    params: { category: cat.name },
  }));
}

const { category } = Astro.params;
const posts = await getPostsByCategory(category);
const categories = await getAllCategories();
const sidebarData = await getSidebarData();
---

<BaseLayout title={`分类：${category}`}>
  <JsonLd
    type="breadcrumb"
    items={[
      { name: '首页', url: SITE_URL },
      { name: '归档', url: `${SITE_URL}/blog/` },
      { name: category, url: `${SITE_URL}/blog/category/${encodeURIComponent(category)}/` },
    ]}
  />
  <PageLayout layout="three-col">
    <div slot="leftSidebar">
      <CategoryList
        categories={categories}
        activeCategory={category}
        client:load
      />
    </div>

    <div slot="rightSidebar">
      <Sidebar data={sidebarData} />
    </div>

    <div class="page-header">
      <h1 class="page-title">分类：{category}</h1>
      <span class="post-count">共 {posts.length} 篇</span>
    </div>

    <PostList posts={posts} pageSize={10} />
  </PageLayout>
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    padding: 20px 24px;
    background: color-mix(in oklch, var(--color-base-200) 90%, transparent);
    border: 1px solid var(--border);
    border-radius: 12px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
  }

  .page-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0;
    color: var(--text-primary);
  }

  .post-count {
    font-size: 14px;
    color: var(--text-secondary);
  }
</style>
